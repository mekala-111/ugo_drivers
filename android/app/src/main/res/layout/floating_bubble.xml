<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Circular Bubble -->
    <FrameLayout
        android:id="@+id/bubble_container"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bubble_background"
        android:elevation="8dp"
        android:contentDescription="Driver quick bubble"
        android:importantForAccessibility="yes"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/bubble_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:src="@drawable/ugo_notification"
            android:scaleType="centerInside"
            android:contentDescription="Open driver app" />

        <!-- Notification Badge -->
        <View
            android:id="@+id/bubble_badge"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bubble_circle_mask"
            android:backgroundTint="#FF4444"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Minimized / Close "X" button appearing on long-press or drag to bottom -->
    <ImageView
        android:id="@+id/close_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@drawable/close_button_bg"
        android:padding="8dp"
        android:contentDescription="Open app and manage status"
        android:visibility="gone" />

</FrameLayout>