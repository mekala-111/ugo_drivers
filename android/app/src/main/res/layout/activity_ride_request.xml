<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:elevation="8dp">

        <!-- Top Banner -->
        <RelativeLayout
            android:id="@+id/top_banner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:paddingHorizontal="20dp">
            
            <TextView
                android:id="@+id/request_type_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW REQUEST"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:id="@+id/timer_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30s"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/card_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:background="#FFFFFF">

            <!-- Distances and Fare -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Horizontal Line behind fare box -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="20dp" />

                <!-- Fare Box Center -->
                <LinearLayout
                    android:id="@+id/fare_box_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerInParent="true"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:gravity="center">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fare"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />
                        
                    <TextView
                        android:id="@+id/ride_fare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹150"
                        android:textColor="#005A93"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:id="@+id/payment_method_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONLINE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Pickup Distance Left -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/fare_box_container"
                    android:layout_marginEnd="12dp"
                    android:background="#FFFFFF"
                    android:gravity="start">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup Distance"
                        android:textColor="#B0B0B0"
                        android:textSize="11sp" />
                        
                    <TextView
                        android:id="@+id/pickup_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="505.4Km"
                        android:textColor="#005A93"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Drop Distance Right -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/fare_box_container"
                    android:layout_marginStart="12dp"
                    android:background="#FFFFFF"
                    android:gravity="end">
                     
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop Distance"
                        android:textColor="#B0B0B0"
                        android:textSize="11sp" />
                        
                    <TextView
                        android:id="@+id/drop_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="581.5Km"
                        android:textColor="#005A93"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- Addresses List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Drop Address Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:id="@+id/drop_pin_container"
                        android:layout_width="60dp"
                        android:layout_height="65dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drop"
                            android:textColor="#B0B0B0"
                            android:textSize="11sp" />
                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:id="@+id/drop_zip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="560095"
                            android:textColor="#D35400"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                            
                        <LinearLayout
                            android:id="@+id/drop_pill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍"
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:id="@+id/drop_main"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Koramangala"
                                android:textColor="#C0392B"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/drop_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Indiranagar, Bangalore"
                            android:textColor="#7F8C8D"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Pickup Address Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:id="@+id/pickup_pin_container"
                        android:layout_width="60dp"
                        android:layout_height="65dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup"
                            android:textColor="#B0B0B0"
                            android:textSize="11sp" />
                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:id="@+id/pickup_zip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="560001"
                            android:textColor="#D35400"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                            
                        <LinearLayout
                            android:id="@+id/pickup_pill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍"
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:id="@+id/pickup_main"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ashok Nagar"
                                android:textColor="#27AE60"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                         <TextView
                            android:id="@+id/pickup_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MG Road, Bangalore"
                            android:textColor="#7F8C8D"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- Bottom Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="100">

                <Button
                    android:id="@+id/btn_decline"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="47"
                    android:text="DECLINE"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" /> 

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="6" />

                <Button
                    android:id="@+id/btn_accept"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="47"
                    android:text="ACCEPT"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" /> 
                    
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
